# Application Configuration
APP_NAME=AP Workflow Agent
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/ap_workflow
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# Supabase Storage Configuration
SUPABASE_URL=https://example.supabase.co
SUPABASE_KEY=your-supabase-key

# Tesseract OCR Configuration
TESSERACT_PATH=tesseract
TESSERACT_TIMEOUT=30

# ECB FX Rates Configuration
ECB_API_URL=https://www.ecb.europa.eu/stats/eurofxref/eurofxref-daily.xml
FX_RATE_CACHE_TTL=86400

# LLM (NVIDIA NIM) Configuration
LLM_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
LLM_API_KEY=your-nvidia-nim-api-key
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b
LLM_FALLBACK_MODEL=meta/llama-3.3-70b-instruct
LLM_RATE_LIMIT_RPM=40
LLM_QUEUE_MAX_SIZE=1000

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_SECONDS=60

# Duplicate Detection Configuration
DUPLICATE_DETECTION_WINDOW_HOURS=72

# Anomaly Detection Configuration
ZSCORE_THRESHOLD=2.5
ZSCORE_MAX_SEVERITY=6.0
ISOLATION_FOREST_N_ESTIMATORS=200
ISOLATION_FOREST_CONTAMINATION=0.025
ISOLATION_FOREST_RETRAIN_INTERVAL_DAYS=7

# Auto-Approval Configuration
DEFAULT_AUTO_APPROVE_MAX_AMOUNT=10000.0

# SLA Deadlines Configuration
AP_CLERK_SLA_HOURS=24
MANAGER_SLA_HOURS=8
CFO_SLA_HOURS=2

# JWT / Auth Configuration
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_HOURS=24

# WebSocket Configuration
WEBSOCKET_PING_INTERVAL=30
WEBSOCKET_PONG_TIMEOUT=5

# Audit Logging Configuration
AUDIT_LOG_RETENTION_DAYS=365

# Email (Gmail IMAP) Configuration
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993

# ERP System Configuration
ERP_API_URL=
ERP_API_KEY=

# Circuit Breaker Configuration
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=60
